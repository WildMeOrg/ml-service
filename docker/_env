# Copy this file to .env and set values for your environment.
#
#   cp _env .env
#
# Required ----------------------------------------------------------------

# Directory containing model weight files (.pt, .weights, .bin, .pth, etc.)
# These are mounted into the container at /models/ — use /models/ paths in model_config.json
MODELS_DIR=/data0/user/models

# The model registry this deployment loads.
#
# MUST live OUTSIDE the git checkout. The repo's app/model_config.json is a small
# development stub; a real deployment's registry is a different, much larger file.
# If it is kept inside the checkout, `git checkout` / `reset --hard` / `stash` / a
# pull that touches that path will silently replace the live registry with the
# stub, and the service will fail to start on the next restart -- taking down every
# install that shares it. Put it next to the weights it references.
MODEL_CONFIG=/data0/user/model_config.json

# Optional ----------------------------------------------------------------

# GPU device ID (default: 0)
# GPU_ID=0

# PyTorch device: cuda, cpu (default: cuda)
# DEVICE=cuda

# Number of uvicorn workers (default: 1 — use 1 for GPU to avoid VRAM contention)
# WORKERS=1

# Host port to expose (default: 6050)
# ML_SERVICE_PORT=6050

# Directory shared with WBIA/Wildbook for image paths (so image_uuid_list file paths resolve)
# DATA_DB_DIR=/data/db
